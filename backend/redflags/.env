SYSTEM_LOG_PATH=/suricata_logs/eve.json
SYSTEM_SOURCE_HOST=dtm-suricata
WEB_LOGS_ENABLED=false
WEB_LOG_PATH=/logs/web.log
WEB_SOURCE_HOST=webserver
