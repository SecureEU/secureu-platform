{
	"info": {
		"_postman_id": "seuxdr-manager-api-collection",
		"name": "SEUXDR Manager API",
		"description": "Comprehensive API collection for SEUXDR Host-based Intrusion Detection System Manager.\n\n## Setup\n1. Set `base_url` variable to your manager URL (e.g., `https://localhost:8443`)\n2. Set `mtls_base_url` variable for mTLS endpoints (e.g., `https://localhost:8081`)\n3. For mTLS endpoints, configure client certificates in Postman Settings\n\n## Authentication\nThe Login request automatically saves the JWT token to the `token` collection variable. All authenticated requests use this token automatically.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "base_url",
			"value": "https://localhost:8443",
			"type": "string"
		},
		{
			"key": "mtls_base_url",
			"value": "https://localhost:8081",
			"type": "string"
		},
		{
			"key": "token",
			"value": "",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "Authentication",
			"description": "User authentication and session management endpoints",
			"item": [
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    var jsonData = pm.response.json();",
									"    if (jsonData.token) {",
									"        pm.collectionVariables.set(\"token\", jsonData.token);",
									"        console.log(\"Token saved to collection variables\");",
									"    }",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"admin\",\n    \"password\": \"your_password\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/login",
							"host": ["{{base_url}}"],
							"path": ["api", "login"]
						},
						"description": "Authenticate user and receive JWT token. The token is automatically saved to collection variables for use in subsequent requests."
					},
					"response": []
				},
				{
					"name": "Register (First Admin)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"admin\",\n    \"password\": \"secure_password\",\n    \"email\": \"admin@example.com\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/register",
							"host": ["{{base_url}}"],
							"path": ["api", "register"]
						},
						"description": "Register the first admin user. This endpoint is only available when no users exist in the system."
					},
					"response": []
				},
				{
					"name": "Logout",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{token}}",
									"type": "string"
								}
							]
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/logout",
							"host": ["{{base_url}}"],
							"path": ["api", "logout"]
						},
						"description": "Logout current user and invalidate the session."
					},
					"response": []
				},
				{
					"name": "Change Password",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{token}}",
									"type": "string"
								}
							]
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"old_password\": \"current_password\",\n    \"new_password\": \"new_secure_password\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/change-password",
							"host": ["{{base_url}}"],
							"path": ["api", "change-password"]
						},
						"description": "Change user password. Used for changing temporary passwords or regular password updates."
					},
					"response": []
				}
			]
		},
		{
			"name": "User Management",
