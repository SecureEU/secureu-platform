							"raw": "{\n    \"agent_uuid\": \"agent-uuid-from-generation\",\n    \"hostname\": \"web-server-01\",\n    \"ip_address\": \"192.168.1.100\",\n    \"os\": \"linux\",\n    \"arch\": \"amd64\",\n    \"version\": \"1.0.0\"\n}"
						},
						"url": {
							"raw": "{{mtls_base_url}}/api/register",
							"host": ["{{mtls_base_url}}"],
							"path": ["api", "register"]
						},
						"description": "Register an agent with the manager using mTLS authentication. This endpoint requires client certificates configured in Postman.\n\n**Setup:**\n1. Go to Settings > Certificates\n2. Add client certificate for the mTLS host\n3. Use the agent's certificate and key files"
					},
					"response": []
				}
			]
		},
