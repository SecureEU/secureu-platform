						"url": {
							"raw": "{{base_url}}/api/keepalive",
							"host": ["{{base_url}}"],
							"path": ["api", "keepalive"]
						},
						"description": "Agent heartbeat to indicate it is still active. Used by agents to maintain connection status."
					},
					"response": []
				}
