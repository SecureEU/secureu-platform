						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"newuser\",\n    \"password\": \"temporary_password\",\n    \"email\": \"newuser@example.com\",\n    \"role_id\": 1,\n    \"org_id\": 1\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/create/user",
							"host": ["{{base_url}}"],
							"path": ["api", "create", "user"]
						},
						"description": "Create a new user account. Requires admin privileges."
					},
					"response": []
				},
				{
					"name": "Update User",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{token}}",
									"type": "string"
								}
							]
						},
						"method": "PUT",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"updateduser\",\n    \"email\": \"updated@example.com\",\n    \"role_id\": 2,\n    \"org_id\": 1\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/update/user/:user_id",
							"host": ["{{base_url}}"],
							"path": ["api", "update", "user", ":user_id"],
							"variable": [
								{
									"key": "user_id",
									"value": "1",
									"description": "User ID to update"
								}
							]
						},
						"description": "Update an existing user's information. Requires admin privileges."
					},
					"response": []
				},
				{
					"name": "List Users",
