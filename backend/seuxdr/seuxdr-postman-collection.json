		{
			"name": "Agents",
			"description": "Agent generation, download, and management",
			"item": [
				{
					"name": "Generate Agent",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{token}}",
									"type": "string"
								}
							]
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"web-server-01\",\n    \"os\": \"linux\",\n    \"arch\": \"amd64\",\n    \"group_id\": 1,\n    \"org_id\": 1\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/create/agent",
							"host": ["{{base_url}}"],
							"path": ["api", "create", "agent"]
						},
						"description": "Generate a new agent binary for deployment. Specify target OS (linux/windows/darwin) and architecture (amd64/arm64)."
					},
					"response": []
				},
				{
					"name": "Download Agent",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{token}}",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/download/agent?uuid=agent-uuid-here",
							"host": ["{{base_url}}"],
							"path": ["api", "download", "agent"],
							"query": [
								{
									"key": "uuid",
									"value": "agent-uuid-here",
									"description": "Agent UUID from generation response"
								}
							]
						},
						"description": "Download the generated agent binary. Use the UUID returned from the Generate Agent request."
					},
					"response": []
				},
				{
					"name": "Download Agent by UUID (Direct)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/download/raw/:agentUUID",
							"host": ["{{base_url}}"],
							"path": ["api", "download", "raw", ":agentUUID"],
							"variable": [
								{
									"key": "agentUUID",
									"value": "agent-uuid-here",
									"description": "Agent UUID for direct download"
								}
							]
						},
						"description": "Direct download of agent binary by UUID. Does not require authentication - uses UUID as access token."
					},
					"response": []
				},
